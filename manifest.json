{
  "manifest_version": 3,
  "name": "Netflix Dual Subs",
  "version": "0.1.0",
  "description": "Dual Japanese + English subtitles on Netflix",
  "permissions": ["storage", "downloads"],
  "host_permissions": ["*://*.netflix.com/*"],
  "web_accessible_resources": [
    {
      "resources": ["intercept.js"],
      "matches": ["*://*.netflix.com/*"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["*://*.netflix.com/*"],
      "js": ["loader.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["*://*.netflix.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "icons": {
    "48": "icon.png",
    "128": "icon.png"
  }
}